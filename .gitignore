# Aerion DAW .gitignore
# ---------------------------------------------------------------------------
# Tracked at the repo root: README.md, LICENSE, .gitignore, .github/, AerionDawCpp/
# Everything else - IDE caches, AI tool folders, build output, installers,
# personal scratch - is intentionally ignored so the root stays minimal.

# ---- Build & packaging output --------------------------------------------
build/
build-*/
out/
dist/
coverage/
_CPack_Packages/
ci-artifacts/

# ---- OS junk -------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---- Logs & env ----------------------------------------------------------
*.log
.env
.env.*
!.env.example

# ---- IDE / editor caches -------------------------------------------------
.vs/
.vscode/
.idea/
*.user
*.suo
*.aps
*.ncb
*.opensdf
*.sdf
*.VC.db
*.vcxproj.user

# ---- AI / assistant tooling (local-only) ---------------------------------
.claude/
.cursor/
Cursor-AI/
Gemini/
.aider*
.copilot/

# ---- Personal scratch ----------------------------------------------------
# Anything you want to keep next to the repo but not commit. Put it under
# scratch/, notes/, or dev/ - none of those names are tracked.
scratch/
notes/
dev/
docs/
scripts/

# ---- Node (only relevant if a JS sub-tool is added later) ----------------
node_modules/

# ---- Steinberg ASIO SDK --------------------------------------------------
# The SDK is bundled in-tree under AerionDawCpp/External/ASIO-SDK_* (GPLv3,
# redistributable) so a fresh clone gets ASIO support out of the box. Do NOT
# add it back to .gitignore unless you switch the licensing model away from
# GPLv3.
